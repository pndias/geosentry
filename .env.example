# GeoSentry - Configurações de API

# Necessário para CrewAI processar a lógica (ex: gpt-4o, gpt-4-turbo)
OPENAI_API_KEY=sua_chave_aqui

# Necessário para o Agente de Busca (https://serper.dev/)
SERPER_API_KEY=sua_chave_aqui

# Opcional: Banco de Dados (PostGIS)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geodata
