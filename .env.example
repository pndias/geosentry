# GeoSentry - API Configuration

# Required for CrewAI to process logic (e.g., gpt-4o, gpt-4-turbo)
OPENAI_API_KEY=your_key_here

# Required for the Search Agent (https://serper.dev/)
SERPER_API_KEY=your_key_here

# Optional: Database (PostGIS)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geodata
